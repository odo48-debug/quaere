# Quaere Engine — Environment Variables
# Copy this file to .env and fill in the values.

# Backend / Server-side Secrets (Set these in your hosting provider's dashboard)
# NEVER add VITE_ to these, or they will be exposed to the browser!
GEMINI_API_KEY=your_google_ai_studio_key
CLERK_SECRET_KEY=sk_test_...

# ──────────────────────────────────────────────────────────────────
# CLERK AUTHENTICATION (OPTIONAL)
# If not provided, the app runs without auth (open-source/local mode).
# Get yours at: https://dashboard.clerk.com
# ──────────────────────────────────────────────────────────────────
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
